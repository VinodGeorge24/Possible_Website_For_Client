# Django Settings
DJANGO_SECRET_KEY=replace-me-with-a-real-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:3000

# Development email
# Use Mailtrap during development, then switch these values to the client's real inbox before launch.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USE_TLS=True
EMAIL_HOST_USER=mailtrap-username
EMAIL_HOST_PASSWORD=mailtrap-password
DEFAULT_FROM_EMAIL=Scottsdale Desert Oasis <hello@example.com>
CONTACT_EMAIL=hello@example.com
INQUIRY_TO_EMAIL=hello@example.com
INQUIRY_BCC_EMAIL=

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Phase 2 placeholders
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
